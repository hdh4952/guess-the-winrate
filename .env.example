# Copy this file to `.env` and paste your token (the .env file is gitignored).
# Lichess personal API token — get one at https://lichess.org/account/oauth/token
# (no scopes are required for the Opening Explorer).
#
# NOTE: VITE_ env vars are embedded in the client bundle and are visible to anyone
# using a deployed app. This is safe for LOCAL play only; for a public deployment
# use a backend proxy that keeps the token server-side.
VITE_LICHESS_TOKEN=
